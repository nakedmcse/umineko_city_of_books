BASE_URL=http://localhost:4323
UPLOAD_DIR=uploads
LOG_LEVEL=debug

# Database connection. Either set DATABASE_URL directly,
# or rely on the discrete POSTGRES_* vars from postgres.env.
# DATABASE_URL=postgres://umineko:foo@localhost:5004/umineko_city_of_books?sslmode=disable
POSTGRES_HOST=localhost
POSTGRES_SSL_MODE=disable
